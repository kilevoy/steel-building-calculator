{
  "name": "metalcalc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "check:references": "node scripts/check_reference_drift.mjs",
    "preview": "vite preview",
    "generate:purlin-ref": "python scripts/extract_purlin_reference.py",
    "generate:column-ref": "python scripts/extract_column_reference.py",
    "generate:truss-ref": "python scripts/extract_truss_reference.py",
    "generate:acceptance-excel": "python scripts/generate_engineering_acceptance_excel_snapshot.py",
    "generate:acceptance-cases": "tsx --tsconfig tsconfig.app.json scripts/generate_engineering_acceptance_cases.ts",
    "generate:acceptance-report": "tsx --tsconfig tsconfig.app.json scripts/generate_engineering_acceptance_auto_report.ts",
    "generate:acceptance-pack": "npm run generate:acceptance-excel && npm run generate:acceptance-cases && npm run generate:acceptance-report",
    "verify": "npm run check:references && npm run lint && npm test && npm run build && npm run test:e2e",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "pdfjs-dist": "^5.4.296",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
